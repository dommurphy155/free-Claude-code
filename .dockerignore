# =============================================================================
# Docker Ignore - Keep image lean and secure
# =============================================================================

# Git
.git
.gitignore
.gitattributes
.gitmodules

# CI/CD
.github
.gitlab-ci.yml
.travis.yml
azure-pipelines.yml

# Documentation (not needed at runtime)
*.md
!README.md
CLAUDE-CODE-SETUP.md
CLAUDE.md
USE_KEYMASTER.md
WIZARD.md
docs/

# Node
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.npm
.yarn
.pnp.*

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
.env
.env.*
!.env.example
*.egg-info/
dist/
build/
.eggs/
*.egg

# Development/IDE
.vscode
.idea
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Testing
test/
tests/
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx
coverage/
.nyc_output/

# Build artifacts
*.log
logs/
tmp/
temp/
*.tmp

# Playwright
playwright-report/
test-results/
playwright/.cache/

# Local data (mount these as volumes instead)
.remember/
.claude/sessions/
.claude/cache/
*.db
*.sqlite
*.sqlite3

# Secrets (never include these)
*.pem
*.key
*.crt
*.p12
*.pfx
secrets/
secret/
.env.local
.env.*.local
.env.telegram

# Host provisioning (not needed in container)
linux_setup_wizard.py
mac_setup_wizard.py
windows_setup_wizard.py
setup_wizard.py
install_keymaster.sh

# Docker files (not needed inside image)
Dockerfile*
docker-compose*.yml
docker-compose*.yaml
.docker/

# Misc
*.tar.gz
*.zip
*.tar
*.tgz
*.rar
